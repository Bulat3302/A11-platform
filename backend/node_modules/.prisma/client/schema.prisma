generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects      Project[]
  palettes      Palette[]
  likes         Like[]
  comments      Comment[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulations Simulation[]
  palettes    Palette[]

  @@map("projects")
}

model Simulation {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  imageUrl   String   @map("image_url")
  visionType String   @map("vision_type") // protanopia | deuteranopia | tritanopia | contrast_loss
  intensity  Float    @default(1.0)
  results    Json? // { totalElements, violations, wcagLevel }
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("simulations")
}

model Palette {
  id          String   @id @default(uuid())
  name        String?
  userId      String   @map("user_id")
  projectId   String?  @map("project_id")
  colors      Json // [{ role, hex, contrast, wcagLevel }]
  wcagLevel   String   @map("wcag_level") // A | AA | AAA | Fail
  isPublished Boolean  @default(false) @map("is_published")
  tags        String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  likes    Like[]
  comments Comment[]

  @@map("palettes")
}

model Like {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  paletteId String   @map("palette_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  palette Palette @relation(fields: [paletteId], references: [id], onDelete: Cascade)

  @@unique([userId, paletteId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  paletteId String   @map("palette_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  palette Palette @relation(fields: [paletteId], references: [id], onDelete: Cascade)

  @@map("comments")
}
